/* 页面整体 */
.chat-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f0f2f5;
}

/* 消息列表 */
.message-list {
  flex: 1;
  padding: 20rpx;
  box-sizing: border-box;
}

/* 消息包装 */
.msg-wrapper {
  display: flex;
  margin-bottom: 30rpx;
  align-items: flex-start;
}

.msg-wrapper.user {
  flex-direction: row-reverse;
}

.msg-wrapper.loading {
  opacity: 0.7;
}

/* 头像 */
.avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  overflow: hidden;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
}

.avatar.bot {
  background: #4a6cf7;
  margin-right: 16rpx;
}

.avatar.user {
  background: #07c160;
  margin-left: 16rpx;
}

/* 气泡 */
.bubble {
  max-width: 70%;
  padding: 20rpx 24rpx;
  border-radius: 16rpx;
  font-size: 30rpx;
  line-height: 1.6;
  word-break: break-all;
}

.bubble.bot {
  background: #fff;
  color: #333;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

.bubble.user {
  background: #07c160;
  color: #fff;
}

.bubble bot rich-text {
  display: block;
}

/* 产品卡片 */
.product-cards {
  margin-top: 20rpx;
}

.product-card {
  background: #fafbfc;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid #e8e8e8;
}

.card-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  padding-bottom: 12rpx;
  border-bottom: 1rpx solid #eee;
}

.model-no {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a2e;
  margin-right: 12rpx;
}

.model-name {
  font-size: 26rpx;
  color: #666;
}

.card-body {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.spec-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.spec-label {
  font-size: 26rpx;
  color: #888;
}

.spec-value {
  font-size: 28rpx;
  color: #333;
}

.spec-value.price {
  color: #e64340;
  font-weight: 600;
}

.spec-row.total {
  margin-top: 8rpx;
  padding-top: 8rpx;
  border-top: 1rpx dashed #ddd;
}

.total-price {
  font-size: 34rpx;
  font-weight: 700;
  color: #e64340;
}

/* 产品图片 */
.card-images {
  display: flex;
  gap: 12rpx;
  margin-top: 16rpx;
  flex-wrap: wrap;
}

.card-images image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 8rpx;
  background: #eee;
}

/* 选项按钮 */
.options-bar {
  margin-top: 20rpx;
}

.options-label {
  font-size: 24rpx;
  color: #888;
  margin-bottom: 12rpx;
}

.options-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.option-btn {
  background: #eef2ff;
  color: #4a6cf7;
  border: 1rpx solid #d0d8f0;
  border-radius: 30rpx;
  padding: 10rpx 28rpx;
  font-size: 28rpx;
  line-height: 1.4;
  margin: 0;
}

.option-btn::after {
  border: none;
}

/* 输入中动画 */
.typing {
  display: flex;
  align-items: center;
}

.dots {
  display: flex;
  margin-left: 12rpx;
  gap: 8rpx;
}

.dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #999;
  animation: bounce 1.4s infinite ease-in-out;
}

.dot:nth-child(1) { animation-delay: 0s; }
.dot:nth-child(2) { animation-delay: 0.2s; }
.dot:nth-child(3) { animation-delay: 0.4s; }

@keyframes bounce {
  0%, 80%, 100% { transform: scale(0.6); opacity: 0.5; }
  40% { transform: scale(1); opacity: 1; }
}

/* 底部输入区 */
.input-area {
  display: flex;
  align-items: center;
  padding: 16rpx 20rpx 32rpx;
  background: #fff;
  border-top: 1rpx solid #e5e5e5;
  gap: 16rpx;
}

.input-box {
  flex: 1;
  background: #f5f5f5;
  border-radius: 40rpx;
  padding: 16rpx 28rpx;
}

.input-box input {
  font-size: 30rpx;
  height: 44rpx;
  line-height: 44rpx;
}

.placeholder {
  color: #aaa;
  font-size: 28rpx;
}

.send-btn {
  background: #c0c0c0;
  color: #fff;
  border-radius: 40rpx;
  padding: 16rpx 36rpx;
  font-size: 30rpx;
  font-weight: 500;
  line-height: 1.4;
  margin: 0;
}

.send-btn::after {
  border: none;
}

.send-btn.active {
  background: #07c160;
}

.send-btn[disabled] {
  background: #ddd;
  color: #fff;
}
