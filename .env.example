# ============================================
# Database (PostgreSQL + pgvector)
# ============================================
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5433/multimodal_rag
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=multimodal_rag

# ============================================
# MinIO (Object Storage)
# ============================================
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=multimodal-rag-catalog
MINIO_SECURE=false

# ============================================
# LLM API Keys
# ============================================
OPENAI_API_KEY=your-openai-api-key
# ANTHROPIC_API_KEY=your-anthropic-api-key

# Local LLM (Ollama / vLLM)
LOCAL_LLM_BASE_URL=http://localhost:11434
LOCAL_LLM_MODEL=qwen2.5:32b

# Multimodal VIE Model
VLM_MODEL=Qwen/Qwen2.5-VL-7B-Instruct
VLM_BASE_URL=http://localhost:8001/v1

# ============================================
# Embedding Models
# ============================================
TEXT_EMBEDDING_MODEL=BAAI/bge-m3
IMAGE_EMBEDDING_MODEL=openai/clip-vit-base-patch32

# ============================================
# Reranker
# ============================================
RERANKER_MODEL=BAAI/bge-reranker-large

# ============================================
# Application
# ============================================
APP_ENV=development
LOG_LEVEL=INFO
UPLOAD_DIR=./data/pdfs
EXTRACTED_DIR=./data/extracted
IMAGE_DIR=./data/images
